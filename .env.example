# --- Brand (single source of truth; overrides brand/brand.config.json) ---
# Rename the whole platform by changing these + running scripts/rename-brand.sh
APP_NAME=SwingAI
APP_SHORT_NAME=SwingAI
APP_LEGAL_NAME=SwingAI
APP_TAGLINE=Disciplined swing trading, proven honestly.
APP_DOMAIN=swingai.in
APP_SUPPORT_EMAIL=support@swingai.in
# Frontend (Next.js) reads these public copies:
NEXT_PUBLIC_APP_NAME=SwingAI
NEXT_PUBLIC_APP_DOMAIN=swingai.in

# --- Phase 0 (no secrets needed; synthetic + yfinance are keyless) ---
DATA_PROVIDER=synthetic        # synthetic (offline dev) | yfinance (real NSE data) | later: angelone, dhan
# For LIVE real-data swing candidates in the dashboard, set:
#   DATA_PROVIDER=yfinance     # backend computes picks from real prices
#   ENABLE_SCHEDULER=true      # run the daily pipeline (3:30 PM IST) + exit checker (3:45 PM IST)
# Without the scheduler you can still populate picks on demand via Admin → "Re-run pipeline".
ENABLE_SCHEDULER=false         # true in prod to run the cron jobs in-process (single instance)

# --- Local infra (Docker, scripts/db.sh) — SwingAI's OWN instances ---
# Separate ports from OmniMark (5433/6379). The control scripts set these for you.
DB_PORT=5434
REDIS_PORT=6380
POSTGRES_USER=swingai
POSTGRES_PASSWORD=swingai
POSTGRES_DB=swingaidb
# Backend uses async SQLite by default (zero infra); the scripts override with Postgres:
# DATABASE_URL=postgresql+asyncpg://swingai:swingai@localhost:5434/swingaidb
# REDIS_URL=redis://localhost:6380/0

# --- Phase 1+ (managed via the encrypted vault, not here in prod) ---
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-1.5-flash

# --- Frontend (Next.js apps) ---
NEXT_PUBLIC_API_BASE=http://localhost:9000
