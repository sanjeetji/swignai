# Copy this file to backend/.env and fill in your real values.
# backend/.env is git-ignored (never committed). The backend reads it on startup.

# --- Data source ---
DATA_PROVIDER=angelone          # synthetic | yfinance | angelone

# --- Angel One SmartAPI (official NSE data) ---
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_CODE=your_client_code      # e.g. AAAA1234
ANGELONE_MPIN=your_mpin_or_password
ANGELONE_TOTP_SECRET=your_base32_totp_secret

# --- DB / Redis (the scripts set these; only needed if running uvicorn by hand) ---
# DATABASE_URL=postgresql+asyncpg://swingai:swingai@localhost:5434/swingaidb
# REDIS_URL=redis://localhost:6380/0

# --- Optional: enable the daily cron jobs in this process ---
# ENABLE_SCHEDULER=true

# --- Optional: error tracking (Sentry). Paste your DSN to turn it on. ---
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
# SENTRY_TRACES_SAMPLE_RATE=0.1
# RELEASE=  # e.g. git sha
