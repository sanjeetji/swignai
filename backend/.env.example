# ============================================================================
# SwingAI — backend environment template
# ----------------------------------------------------------------------------
# Copy to backend/.env and fill in real values:   cp .env.example .env
# backend/.env is git-ignored (never committed). The backend reads it on startup.
#
# TWO WAYS TO SET SECRETS (you can use either; the vault wins):
#   1. Admin → Integrations tab  → encrypted DB vault   (preferred in production)
#   2. This .env file            → plain fallback        (used when the vault is empty)
# Resolution order for every provider below is:  Integrations vault → .env.
# So you may leave a key blank here and paste it in the Integrations tab instead.
# ============================================================================


# ─── Environment ────────────────────────────────────────────────────────────
ENV=dev                          # dev | staging | prod  (prod hides reset tokens, enforces secrets)
DEBUG=true

# ─── Database / Redis ───────────────────────────────────────────────────────
# The dev scripts set these automatically; only needed if you run uvicorn by hand
# or deploy to your own host. Prod = managed Postgres (Supabase/Neon/RDS).
# DATABASE_URL=postgresql+asyncpg://swingai:swingai@localhost:5434/swingaidb
# REDIS_URL=redis://localhost:6380/0

# ─── Security (MUST be overridden in prod with long random values) ──────────
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SECRET=change-me-to-a-long-random-string
# SECRET_VAULT_KEY=change-me-32+chars-used-to-encrypt-the-integrations-vault
# ACCESS_TOKEN_TTL_MIN=60
# REFRESH_TOKEN_TTL_DAYS=30

# ─── Market data source ─────────────────────────────────────────────────────
DATA_PROVIDER=angelone           # synthetic | yfinance | angelone | dhan
# DATA_PROVIDER_FALLBACK=dhan     # optional: auto fail-over if the primary errors/empties
# DEFAULT_CAPITAL=100000

# Angel One SmartAPI (official NSE data)  ── Integrations provider: "angelone"
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_CODE=your_client_code          # e.g. AAAA1234 (your Angel One login id)
ANGELONE_MPIN=your_mpin_or_password
ANGELONE_TOTP_SECRET=your_base32_totp_secret   # from Angel's enable-TOTP screen

# Dhan (optional fallback NSE data)        ── Integrations provider: "dhan"
# DHAN_CLIENT_ID=your_dhan_client_id
# DHAN_ACCESS_TOKEN=your_dhan_access_token

# ─── LLM providers (Hinglish explanations) ──────────────────────────────────
# LLM_PROVIDER=auto picks the first provider that has a key (Groq-first, then the rest).
# Pin a single one (groq|openrouter|together|openai|gemini) or "template" for no-LLM.
LLM_PROVIDER=auto
# Groq (fast, generous free tier)          ── Integrations provider: "groq"
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenRouter (one key → many models)       ── Integrations provider: "openrouter"
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Together AI                              ── Integrations provider: "together"
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo-Free
# OpenAI                                   ── Integrations provider: "openai"
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Google Gemini                            ── Integrations provider: "gemini"
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Payments — Razorpay ───────────────────  ── Integrations provider: "razorpay"
# Dashboard → Settings → API Keys (use test keys until go-live). Webhook secret is set
# when you create the webhook in the Razorpay dashboard.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Email (SMTP) ─────────────────────────────  ── Integrations provider: "smtp"
# Works with any provider. Examples:
#   Gmail:     host=smtp.gmail.com    port=587  user=you@gmail.com  pass=APP-PASSWORD
#   SendGrid:  host=smtp.sendgrid.net port=587  user=apikey         pass=SG.xxxx
#   AWS SES:   host=email-smtp.<region>.amazonaws.com port=587  user=SMTP-USER pass=SMTP-PASS
# Leave SMTP_HOST blank to disable (dev just logs the email).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=SwingAI <no-reply@swingai.in>

# ─── SMS / WhatsApp — Twilio ──────────────────  ── Integrations provider: "twilio"
# TWILIO_FROM may be a number (+15550001111 for SMS) or "whatsapp:+1..." for WhatsApp.
# Leave blank to disable (dev just logs).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Background jobs (cron) ─────────────────────────────────────────────────
# ENABLE_SCHEDULER=true            # run daily pipeline / exit-checker / SEO in THIS process

# ─── Frontend revalidation (ISR) ────────────────────────────────────────────
# Must match the marketing app's REVALIDATE_TOKEN so the backend can refresh pages.
# REVALIDATE_URL=http://localhost:9002/api/revalidate
# REVALIDATE_TOKEN=dev-revalidate-token-change-me

# ─── Error tracking (Sentry) — optional ─────────────────────────────────────
# SENTRY_DSN=https://xxxx@oyyyy.ingest.sentry.io/zzzz
# SENTRY_TRACES_SAMPLE_RATE=0.1
# RELEASE=                         # e.g. git sha, for release tagging

# ─── Misc ───────────────────────────────────────────────────────────────────
# RATE_LIMIT_PER_MIN=120
# GEOIP_ENABLED=false              # IP→city lookup on login (DPDP: needs consent)
